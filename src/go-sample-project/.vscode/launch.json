{
  // Launch the book server with the debugger attached.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Book Server",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/bookserver",
      "env": {
        "PORT": "8080"
      }
    },
    {
      "name": "Test Current Package",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "args": ["-v", "-race"]
    }
  ]
}
